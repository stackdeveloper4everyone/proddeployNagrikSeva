APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

SARVAM_API_KEY=your_sarvam_api_key
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_CHAT_MODEL=sarvam-105b
SARVAM_CHAT_MAX_TOKENS=900
SARVAM_CHAT_TIMEOUT_SECONDS=45
SARVAM_TRANSLATION_TARGET=en-IN
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh

TAVILY_API_KEY=your_tavily_api_key

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=citizen_policy_knowledge
QDRANT_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

MEM0_API_KEY=
MEM0_ORG_ID=
MEM0_PROJECT_ID=

ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
TRUSTED_SEARCH_DOMAINS=gov.in,nic.in,india.gov.in,myscheme.gov.in
RATE_LIMIT_PER_MINUTE=30
